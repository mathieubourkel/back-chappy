{
  "kind": "collectionType",
  "collectionName": "app_users",
  "info": {
    "singularName": "app-user",
    "pluralName": "app-users",
    "displayName": "app_user",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "firstName": {
      "type": "string",
      "required": true
    },
    "lastName": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "city": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "zip": {
      "type": "integer"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "en attente",
        "actif"
      ]
    },
    "company": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::company.company"
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "inversedBy": "app_users"
    },
    "step_tasks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::step-task.step-task",
      "inversedBy": "app_users"
    }
  }
}
