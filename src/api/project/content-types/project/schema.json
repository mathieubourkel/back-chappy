{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "project",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "budget": {
      "type": "float",
      "required": false
    },
    "description": {
      "type": "text",
      "required": true
    },
    "status": {
      "type": "integer",
      "required": true,
      "unique": false,
      "default": 0
    },
    "companies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::company.company",
      "inversedBy": "projects"
    },
    "estimEndDate": {
      "type": "date"
    },
    "project_steps": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project-step.project-step",
      "mappedBy": "project"
    },
    "users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "projects_collab"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "projects"
    },
    "code": {
      "type": "string",
      "unique": true,
      "required": true,
      "minLength": 16,
      "maxLength": 16
    }
  }
}
